# --- Application Settings ---
APP_NAME="Marketing Agents API"
DEBUG=True

# --- Supabase Configuration ---
# Your Supabase Project URL (e.g., https://xyz.supabase.co)
SUPABASE_URL="https://your-project.supabase.co"
# Your Supabase Service Role Key or Anon Key
SUPABASE_KEY="your-supabase-key"
# JWT Secret from Supabase Settings -> API to validate auth tokens
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# --- Database Configuration ---
# Connection string for Supabase Postgres (using asyncpg driver)
# Format: postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
DATABASE_URL="postgresql+asyncpg://postgres:password@db.your-ref.supabase.co:5432/postgres"

# --- Redis Configuration ---
# Use 'redis' as the hostname if running via Docker Compose
REDIS_URL="redis://redis:6379/0"

# --- LLM Provider API Keys ---
OPENAI_API_KEY="sk-..."
CLAUDE_API_KEY="sk-ant-..."
GEMINI_API_KEY="..."
KIMI_API_KEY="..."

# --- Infrastructure ---
# (Optional) Celery concurrency is handled via CMD in Dockerfile.worker
